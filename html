<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Letter & Number Game</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

  <div class="container">
    <h1>Guess the Type</h1>

    <!-- Display Window -->
    <div id="display">?</div>

    <!-- Buttons -->
    <div class="buttons">
      <button id="letterBtn">L</button>
      <button id="startBtn">Start</button>
      <button id="numberBtn">N</button>
    </div>

    <!-- Result -->
    <p id="result"></p>
  </div>

  <script src="script.js"></script>
</body>
</html>
